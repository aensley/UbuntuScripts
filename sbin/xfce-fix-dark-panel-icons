#!/usr/bin/env bash
#
# xfce-fix-dark-panel-icons — make the black panel icons in the B00merang
# Windows-10(-Dark) icon theme show up on a dark panel.
#
# The theme's raster status icons (e.g. audio-volume-*.png) are solid black
# glyphs with no fallback, so the volume plugin renders black-on-black. This
# recolors those PNGs to white, preserving each glyph's shape (alpha).
#
#   ./xfce-fix-dark-panel-icons          # fix the sound/volume icons (default)
#   ./xfce-fix-dark-panel-icons --all    # whiten every status icon (battery, etc.)
#
# Run as your normal user. A one-time backup is made so you can revert.
#
set -euo pipefail

THEME_DIR="$HOME/.icons/Windows-10"     # where the makeover script installs it
MODE="${1:-audio}"

case "$MODE" in
  audio)     PATTERN='audio-volume-*.png'; SCOPE="sound/volume icons" ;;
  --all|all) PATTERN='*.png';              SCOPE="all status icons" ;;
  *) echo "Usage: $0 [audio|--all]" >&2; exit 1 ;;
esac

if [ ! -d "$THEME_DIR" ]; then
  echo "Icon theme not found at $THEME_DIR" >&2
  echo "If you installed it elsewhere, edit THEME_DIR at the top of this script." >&2
  exit 1
fi

# ImageMagick provides the recolor; install if missing.
TOOL=$(command -v magick || command -v convert || true)
if [ -z "$TOOL" ]; then
  echo "Installing ImageMagick..."
  sudo apt-get update && sudo apt-get install -y imagemagick
  TOOL=$(command -v magick || command -v convert)
fi

# One-time backup of the status icons.
BACKUP="$THEME_DIR/.status-icons-backup.tgz"
if [ ! -f "$BACKUP" ]; then
  echo "Backing up original status icons -> $BACKUP"
  ( cd "$THEME_DIR" && tar czf "$BACKUP" ./*/status 2>/dev/null ) || true
fi

# Recolor: set RGB to white, leave the alpha channel (the glyph shape) untouched.
count=0
while IFS= read -r -d '' f; do
  if "$TOOL" "$f" -channel RGB -evaluate set 100% "$f.tmp" 2>/dev/null; then
    mv "$f.tmp" "$f"
    count=$((count + 1))
  else
    rm -f "$f.tmp"
  fi
done < <(find "$THEME_DIR" -path '*/status/*' -name "$PATTERN" -print0)

echo "Whitened $count file(s) ($SCOPE)."

# Refresh the icon cache and reload the panel so the change shows now.
gtk-update-icon-cache -f "$THEME_DIR" >/dev/null 2>&1 || true
xfce4-panel -r 2>/dev/null || true

echo "Done. If it still looks dark, log out and back in."
echo "Revert with:  tar xzf \"$BACKUP\" -C \"$THEME_DIR\""
